{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "App": {
    "Name": "FulSpectrum"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=FulSpectrum;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },

  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "FulSpectrum.Api",
    "Audience": "FulSpectrum.Web",
    "SecretKey": "CHANGE_THIS_SUPER_LONG_SECRET_KEY_FOR_PRODUCTION_1234567890",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}
